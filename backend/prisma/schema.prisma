generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  name         String?
  cars         Car[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Car {
  id           String   @id @default(cuid())
  name         String
  brand        String
  price        Int
  condition    String   @default("Used")
  images       String   @default("[]")
  state        String
  district     String
  status       String   @default("Pending")
  sellerType   String   @default("User")
  sellerId     String
  vehicleType  String   @default("Car")
  year         Int      @default(2024)
  phone        String   @default("7010587940")
  locationLink String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  seller       User     @relation(fields: [sellerId], references: [id])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  priceCents  Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Dealer {
  id           String   @id @default(cuid())
  name         String
  state        String
  district     String
  phone        String
  email        String
  brands       String   @default("[]")
  dealerType   String   @default("Both")
  imageUrl     String?
  rating       Float    @default(0.0)
  verified     Boolean  @default(false)
  active       Boolean  @default(true)
  locationLink String?
  experience   String   @default("10+ years")
  speciality   String   @default("Automotive Care")
  openingHours String   @default("9 AM - 8 PM")
  services     String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


enum Role {
  USER
  ADMIN
}

model RepairJob {
  id          String   @id @default(cuid())
  title       String
  description String
  vehicleType String   @default("Car")
  beforeImage String
  afterImage  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
